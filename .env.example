# Option A: paste a token directly from Spotify's "Try it" console (expires in ~1h)
# SPOTIFY_TOKEN=your_token_here

# Option B: OAuth flow — get credentials at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Spotify playlist URL or ID to import
SOURCE_PLAYLIST=https://open.spotify.com/playlist/YOUR_PLAYLIST_ID

# Sort mode: dj | listen | adrenaline
SORT_MODE=listen

# New playlist name (leave empty to auto-name as "Original Name [Sorted]")
NEW_PLAYLIST_NAME=

# Make the new playlist public? true | false
NEW_PLAYLIST_PUBLIC=false